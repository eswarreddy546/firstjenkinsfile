pipeline {
    agent { label 'AGENT-1' }

    environment {
        course = "DevOps321"
    }

    stages {

        stage('Build') {
            steps {
                echo "Hello Build"
                echo "${course}"
            }
        }

        stage('Test') {
            steps {
                echo "Hello Test"
                echo "${course}"
            }
        }

        stage('Deploy') {
            steps {
                echo "Hello Deploy"
                echo "${course}"
            }
        }

    }

    post {

        always {
            echo 'I will always say Hello again!'
            cleanWs()
        }

        success {
            echo 'I will run if success'
        }

        failure {
            echo 'I will run if failure'
        }

    }
}